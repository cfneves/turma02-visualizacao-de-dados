   ],
   "source": [
    "# ── Estatísticas sobre o array 1D de salários ────────────────────────────\n",
    "print(\"=== Estatísticas dos Salários ===\")\n",
    "print(f\"  np.mean   : R$ {np.mean(salarios):>10,.2f}\")\n",
    "print(f\"  np.median : R$ {np.median(salarios):>10,.2f}\")\n",
