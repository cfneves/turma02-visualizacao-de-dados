     "text": [
      "pandas Series:\n",
      "  type  : <class 'pandas.Series'>\n",
      "  index : [0, 1, 2, 3, 4] ...\n",
      "  values: [ 9088.34  8155.98 14027.93  6647.97  8730.19]\n",
      "\n",
