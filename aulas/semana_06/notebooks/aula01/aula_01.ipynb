      "Total de linhas com pelo menos 1 NaN: 45\n"
     ]
    }
   ],
   "source": [
    "# isnull() retorna True onde há NaN — soma conta os True por coluna\n",
    "nan_por_coluna = df_sujo.isnull().sum()\n",
    "print(\"=== NaN por coluna ===\")\n",
    "print(nan_por_coluna.to_string())\n",
    "\n",
