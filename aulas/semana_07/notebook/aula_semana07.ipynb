    "# Passo 1: encontrar a tag <h3>\n",
    "tag_h3 = primeiro_livro.find('h3')\n",
    "\n",
    "# Passo 2: dentro da <h3>, encontrar o link <a>\n",
    "tag_link = tag_h3.find('a')\n",
