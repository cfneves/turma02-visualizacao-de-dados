   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "# Buscar TODOS os livros na página\n",
    "# Cada livro está dentro de uma tag <article class='product_pod'>\n",
    "\n",
    "livros = soup.find_all('article', class_='product_pod')\n",
