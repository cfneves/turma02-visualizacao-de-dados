   "source": [
    "#### 4. Crie uma tabela de metas de headcount() por departamento com `pd.DataFrame`<br> faça `merge left` com o total por departamento. Identifique se a meta foi atingida."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "14048128",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Tabela de Metas:\n",
      "Departamento  Meta_Salario\n",
      "    Producao          9100\n",
      "          RH          8900\n",
      "  Financeiro          8600\n",
      "   Logística          8400\n",
      "          TI          8350\n",
      "      Vendas          8000\n"
     ]
    }
   ],
   "source": [
    "resumo = df.groupby(\"Departamento\")[\"Salario\"].mean().reset_index()\n",
    "resumo.columns = [\"Departamento\", \"media\"]\n",
    "\n",
    "meta_depto = pd.DataFrame({\n",
    "    \"Departamento\": [\n",
    "        \"Producao\", \"RH\", \"Financeiro\", \"Logística\", \"TI\", \"Vendas\"\n",
    "    ],\n",
    "    \"Meta_Salario\": [9100, 8900, 8600, 8400, 8350, 8000]\n",
    "})\n",
    "\n",
    "print(\"Tabela de Metas:\")\n",
    "print(meta_depto.to_string(index=False))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "5e077719",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Departamento       media  Meta_Salario  Diferenca Status_Meta\n",
      "  Financeiro 8333.119577          8600    -266.88    ❌ Abaixo\n",
      "   Logística 8881.656218          8400     481.66     ✅ Acima\n",
      "          RH 8791.578976          8900    -108.42    ❌ Abaixo\n",
      "          TI 8142.914286          8350    -207.09    ❌ Abaixo\n",
      "      Vendas 8317.084750          8000     317.08     ✅ Acima\n"
     ]
    }
   ],
   "source": [
    "compare = pd.merge(\n",
    "    resumo[[\"Departamento\", \"media\"]],\n",
    "    meta_depto,\n",
    "    on=\"Departamento\",\n",
    "    how=\"inner\"\n",
    ")\n",
    "\n",
    "compare[\"Diferenca\"] = (compare[\"media\"] - compare[\"Meta_Salario\"]).round(2)\n",
    "compare[\"Status_Meta\"] = compare[\"Diferenca\"].apply(\n",
    "    lambda x: \"✅ Acima\" if x >= 0 else \"❌ Abaixo\"\n",
    ")\n",
    "\n",
    "print(compare.to_string(index=False))"
   ]
  },
