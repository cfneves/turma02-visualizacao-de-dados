    "plt.title(\"Salário Médio Real vs Meta por Departamento\")\n",
    "plt.ylabel(\"Salário (R$)\")\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
