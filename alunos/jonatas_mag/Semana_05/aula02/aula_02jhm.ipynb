   ],
   "source": [
    "# Criando uma tabela cruzada de salário por departamento e cargo\n",
    "pivot = pd.pivot_table(\n",
    "    df,\n",
    "    values=\"Salario\",\n",
    "    index=\"Departamento\",\n",
    "    columns=\"Cargo\",\n",
    "    aggfunc=\"mean\",\n",
    "    fill_value=0,\n",
    ").round(0)\n",
    "\n",
    "print(pivot.to_string())\n"
   ]
