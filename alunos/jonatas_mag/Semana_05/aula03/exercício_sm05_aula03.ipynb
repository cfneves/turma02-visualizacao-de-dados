      "Millennial  : R$ 8,814.86 - 362 (36200%)\n",
      "Gen Z       : R$ 8,556.57 - 193 (19300%)\n"
     ]
    }
   ],
   "source": [
    "geracoes = [\"Boomer\", \"Ger X\", \"Millennial\", \"Gen Z\"]\n",
    "for g in geracoes:\n",
    "    mask = geracao == g\n",
    "    media = salarios[mask].mean()\n",
    "    print(f\"{g:12s}: R$ {media:,.2f} - {mask.sum()} ({mask.sum() * 100:.0f}%)\")"
   ]
  },
