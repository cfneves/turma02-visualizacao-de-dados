    "4. Use `np.where()` para criar o array `geração`:\n",
    "   - `\"Boomer\"` se Idade >= 60\n",
    "   - `\"Gen X\"` se Idade >= 44\n",
    "   - `\"Millennial\"` se Idade >= 28\n",
    "   - `\"Gen Z\"` se Idade < 28<br>\n",
    "*(Use `np.select()` com as quatro condições.)*"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 199,
   "id": "fbc82d1a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Acima de 60 :  112 Geração Boomer     - 11.20%\n",
      "Acima de 44 :  333 Geração X          - 33.30%\n",
      "Acima de 28 :  362 Geração Millennium - 36.20%\n",
      "Abaixo de 28:  193 Geração Z          - 19.30%\n"
     ]
    }
   ],
   "source": [
    "# Exemplo de idades apenas para o código rodar\n",
    "idades = np.array(df.Idade)\n",
    "\n",
    "# CORREÇÃO: Aninhando os np.where corretamente (3 argumentos por vez)\n",
    "geracao = np.where(idades >= 60, \"Boomer\",\n",
    "          np.where(idades >= 44, \"Ger X\",\n",
    "          np.where(idades >= 28, \"Millennial\", \"Gen Z\")))\n",
    "\n",
    "# Agora a contagem por igualdade vai funcionar perfeitamente!\n",
    "id_max60 = (geracao == \"Boomer\").sum()\n",
    "id_max44 = (geracao == \"Ger X\").sum()\n",
    "id_max28 = (geracao == \"Millennial\").sum()\n",
    "id_menor28 = (geracao == \"Gen Z\").sum()\n",
    "\n",
    "print(f\"Acima de 60 : {id_max60:4d} Geração Boomer     - {id_max60 /len(idades) * 100:.2f}%\")\n",
    "print(f\"Acima de 44 : {id_max44:4d} Geração X          - {id_max44 /len(idades) * 100:.2f}%\")\n",
    "print(f\"Acima de 28 : {id_max28:4d} Geração Millennium - {id_max28 /len(idades) * 100:.2f}%\")\n",
    "print(f\"Abaixo de 28: {id_menor28:4d} Geração Z          - {id_menor28 /len(idades) * 100:.2f}%\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 196,
   "id": "5df21780",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "Classificação por Geração:\n",
      "  Ger. Boomer   :  112 funcionários - 11.20%\n",
      "  Ger. Milenio  :  362 funcionários - 36.20%\n",
      "  Geração X     :  333 funcionários - 33.30%\n",
      "  Geração Z     :  193 funcionários - 19.30%\n"
     ]
    }
   ],
   "source": [
    "# Com `np.select()` para mostrar as quatro condições.\n",
    "idades = df[\"Idade\"].to_numpy()\n",
    "\n",
    "conds = [\n",
    "    idades >= 60,\n",
    "    idades >= 44,\n",
    "    idades >= 28,\n",
    "]\n",
    "cats = [\"Ger. Boomer\", \"Geração X\", \"Ger. Milenio\"]\n",
    "\n",
    "geracao = np.select(conds, cats, default=\"Geração Z\")\n",
    "print(\"\\nClassificação por Geração:\")\n",
    "\n",
    "faixas, contagens = np.unique(geracao, return_counts=True)\n",
    "# Agora o zip combina a geração correta com a sua respectiva contagem\n",
    "for f, c in zip(faixas, contagens):\n",
    "    porcentagem = (c / len(geracao)) * 100\n",
    "    print(f\"  {f:14s}: {c:4d} funcionários - {porcentagem:.2f}%\")"
   ]
  },
