   "source": [
    "# Funcionários de maior salário: os 10 maiores por ordem\n",
    "indices_ordenados = np.argsort(salarios)           # índices que ordenariam o array\n",
    "top10_idx = indices_ordenados[-10:][::-1]            # últimos 5, do maior para menor\n",
    "print(\"\\nTop 10 salários:\")\n",
    "for idx in top10_idx:\n",
