      "       5     1.045939\n",
      "       6    -1.041725\n",
      "       7    -1.600748\n",
      "       8    -1.481512\n",
      "       9     1.349345\n"
     ]
    }
   ],
   "source": [
    "salarios = df[\"Salario\"].to_numpy()\n",
    "\n",
    "salario_normalizado = (salarios - salarios.mean()) / salarios.std()\n",
    "\n",
    "print(f\"Média após normalização : {salario_normalizado.mean():.6f}\")\n",
    "print(f\"Desvio após normalização: {salario_normalizado.std():.6f}\")\n",
    "\n",
    "print(\"\\nSalários revisados e normalizados\")\n",
    "print(f\"{'Índice':>8} {'Normalizado':>12}\")\n",
    "print(\"-\" * 42)\n",
    "for i, (orig, norm) in enumerate(zip(salarios[:10], salario_normalizado[:10])):\n",
    "    print(f\"{i:>8} {norm:>12.6f}\")"
   ]
  },
