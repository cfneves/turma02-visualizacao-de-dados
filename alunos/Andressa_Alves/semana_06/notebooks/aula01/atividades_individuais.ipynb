      "6 - km/h para m/s\n",
      "0 - Sair\n",
      "65.0 m/s = 234.00 km/h\n",
      "\n",
      "===== MENU DE CONVERSÃO =====\n",
      "1 - Celsius para Fahrenheit\n",
      "2 - Fahrenheit para Celsius\n",
      "3 - Bar para PSI\n",
      "4 - PSI para Bar\n",
      "5 - m/s para km/h\n",
      "6 - km/h para m/s\n",
      "0 - Sair\n",
      "Encerrando o programa...\n"
     ]
    }
   ],
   "source": [
    "def celsius_para_fahrenheit(c):\n",
    "    return (c * 9/5) + 32\n",
    "\n",
    "\n",
    "def fahrenheit_para_celsius(f):\n",
    "    return (f - 32) * 5/9\n",
    "\n",
    "\n",
    "def bar_para_psi(b):\n",
    "    return b * 14.504\n",
    "\n",
    "\n",
    "def psi_para_bar(p):\n",
    "    return p / 14.504\n",
    "\n",
    "\n",
    "def ms_para_kmh(m):\n",
    "    return m * 3.6\n",
    "\n",
    "\n",
    "def kmh_para_ms(k):\n",
    "    return k / 3.6\n",
    "\n",
    "\n",
    "while True:\n",
    "    print('\\n===== MENU DE CONVERSÃO =====')\n",
    "    print('1 - Celsius para Fahrenheit')\n",
    "    print('2 - Fahrenheit para Celsius')\n",
    "    print('3 - Bar para PSI')\n",
    "    print('4 - PSI para Bar')\n",
    "    print('5 - m/s para km/h')\n",
    "    print('6 - km/h para m/s')\n",
    "    print('0 - Sair')\n",
    "\n",
    "    opcao = input('Escolha uma opção: ')\n",
    "\n",
    "    if opcao == '0':\n",
    "        print('Encerrando o programa...')\n",
    "        break\n",
    "\n",
    "    valor = float(input('Digite o valor a ser convertido: '))\n",
    "\n",
    "    if opcao == '1':\n",
    "        resultado = celsius_para_fahrenheit(valor)\n",
    "        print(f'{valor} °C = {resultado:.2f} °F')\n",
    "    elif opcao == '2':\n",
    "        resultado = fahrenheit_para_celsius(valor)\n",
    "        print(f'{valor} °F = {resultado:.2f} °C')\n",
    "    elif opcao == '3':\n",
    "        resultado = bar_para_psi(valor)\n",
    "        print(f'{valor} bar = {resultado:.2f} PSI')\n",
    "    elif opcao == '4':\n",
    "        resultado = psi_para_bar(valor)\n",
    "        print(f'{valor} PSI = {resultado:.2f} bar')\n",
    "    elif opcao == '5':\n",
    "        resultado = ms_para_kmh(valor)\n",
    "        print(f'{valor} m/s = {resultado:.2f} km/h')\n",
    "    elif opcao == '6':\n",
    "        resultado = kmh_para_ms(valor)\n",
    "        print(f'{valor} km/h = {resultado:.2f} m/s')\n",
    "    else:\n",
    "        print('Opção inválida!')"
   ]
  },
