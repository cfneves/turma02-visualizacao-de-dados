    "dados_semana = [\n",
    "    {\"dia\": \"Segunda\",  \"turno\": \"Manhã\",  \"operador\": \"Ana\",    \"pecas\": 520, \"defeitos\": 8},\n",
    "    {\"dia\": \"Segunda\",  \"turno\": \"Tarde\",  \"operador\": \"Bruno\",  \"pecas\": 495, \"defeitos\": 18},\n",
    "    {\"dia\": \"Segunda\",  \"turno\": \"Noite\",  \"operador\": \"Carla\",  \"pecas\": 485, \"defeitos\": 5},\n",
    "    {\"dia\": \"Terça\",    \"turno\": \"Manhã\",  \"operador\": \"Daniel\", \"pecas\": 510, \"defeitos\": 12},\n",
    "    {\"dia\": \"Terça\",    \"turno\": \"Tarde\",  \"operador\": \"Ana\",    \"pecas\": 530, \"defeitos\": 6},\n",
    "    {\"dia\": \"Terça\",    \"turno\": \"Noite\",  \"operador\": \"Bruno\",  \"pecas\": 340, \"defeitos\": 25},\n",
    "    {\"dia\": \"Quarta\",   \"turno\": \"Manhã\",  \"operador\": \"Carla\",  \"pecas\": 560, \"defeitos\": 4},\n",
    "    {\"dia\": \"Quarta\",   \"turno\": \"Tarde\",  \"operador\": \"Daniel\", \"pecas\": 475, \"defeitos\": 30},\n",
    "    {\"dia\": \"Quarta\",   \"turno\": \"Noite\",  \"operador\": \"Ana\",    \"pecas\": 500, \"defeitos\": 7},\n",
    "    {\"dia\": \"Quinta\",   \"turno\": \"Manhã\",  \"operador\": \"Bruno\",  \"pecas\": 545, \"defeitos\": 9},\n",
    "    {\"dia\": \"Quinta\",   \"turno\": \"Tarde\",  \"operador\": \"Carla\",  \"pecas\": 490, \"defeitos\": 11},\n",
    "    {\"dia\": \"Quinta\",   \"turno\": \"Noite\",  \"operador\": \"Daniel\", \"pecas\": 465, \"defeitos\": 6},\n",
    "    {\"dia\": \"Sexta\",    \"turno\": \"Manhã\",  \"operador\": \"Ana\",    \"pecas\": 580, \"defeitos\": 3},\n",
    "    {\"dia\": \"Sexta\",    \"turno\": \"Tarde\",  \"operador\": \"Bruno\",  \"pecas\": 500, \"defeitos\": 14},\n",
    "    {\"dia\": \"Sexta\",    \"turno\": \"Noite\",  \"operador\": \"Carla\",  \"pecas\": 455, \"defeitos\": 8},\n",
    "]\n",
    "\n",
    "\n",
    "def taxa_defeito(pecas, defeitos):\n",
    "    return (defeitos / pecas) * 100 if pecas else 0\n",
    "\n",
    "\n",
    "def resumo_por_turno():\n",
    "    print('\\n=== RESUMO POR TURNO ===')\n",
    "    por_turno = {}\n",
    "    for item in dados_semana:\n",
    "        turno = item['turno']\n",
    "        por_turno.setdefault(turno, {'pecas': 0, 'defeitos': 0, 'registros': 0})\n",
    "        por_turno[turno]['pecas'] += item['pecas']\n",
    "        por_turno[turno]['defeitos'] += item['defeitos']\n",
    "        por_turno[turno]['registros'] += 1\n",
    "\n",
    "    for turno, dados in por_turno.items():\n",
    "        media = dados['pecas'] / dados['registros']\n",
    "        tx = (dados['defeitos'] / dados['pecas']) * 100 if dados['pecas'] else 0\n",
    "        print(f'{turno}: média de produção {media:.0f} peças, defeitos {dados[\"defeitos\"]}, taxa {tx:.2f}%')\n",
    "\n",
    "\n",
    "def melhor_e_pior_dia():\n",
    "    print('\\n=== MELHOR E PIOR DIA ===')\n",
    "    por_dia = {}\n",
    "    for item in dados_semana:\n",
    "        dia = item['dia']\n",
    "        por_dia.setdefault(dia, {'pecas': 0, 'defeitos': 0})\n",
    "        por_dia[dia]['pecas'] += item['pecas']\n",
    "        por_dia[dia]['defeitos'] += item['defeitos']\n",
    "\n",
    "    melhores = sorted(por_dia.items(), key=lambda x: (x[1]['defeitos'] / x[1]['pecas'], x[0]))\n",
    "    melhor_dia = melhores[0]\n",
    "    pior_dia = melhores[-1]\n",
    "    print(f'Melhor dia: {melhor_dia[0]} com taxa {taxa_defeito(melhor_dia[1][\"pecas\"], melhor_dia[1][\"defeitos\"]):.2f}%')\n",
    "    print(f'Pior dia: {pior_dia[0]} com taxa {taxa_defeito(pior_dia[1][\"pecas\"], pior_dia[1][\"defeitos\"]):.2f}%')\n",
    "\n",
    "\n",
    "def ranking_operadores():\n",
    "    print('\\n=== RANKING DOS OPERADORES ===')\n",
    "    por_operador = {}\n",
    "    for item in dados_semana:\n",
    "        op = item['operador']\n",
    "        por_operador.setdefault(op, {'pecas': 0, 'defeitos': 0})\n",
    "        por_operador[op]['pecas'] += item['pecas']\n",
    "        por_operador[op]['defeitos'] += item['defeitos']\n",
    "\n",
    "    ranking = sorted(\n",
    "        por_operador.items(),\n",
    "        key=lambda x: (x[1]['pecas'] - x[1]['defeitos'], x[1]['defeitos']),\n",
    "        reverse=True\n",
    "    )\n",
    "    for pos, (operador, dados) in enumerate(ranking, start=1):\n",
    "        eficiencia = dados['pecas'] - dados['defeitos']\n",
    "        print(f'{pos}. {operador} — eficiência {eficiencia} peças, taxa de defeito {taxa_defeito(dados[\"pecas\"], dados[\"defeitos\"]):.2f}%')\n",
    "\n",
    "\n",
    "def alertas_defeito():\n",
    "    print('\\n=== ALERTAS DE TAXA DE DEFEITO > 3% ===')\n",
    "    alertas = []\n",
    "    for item in dados_semana:\n",
    "        tx = taxa_defeito(item['pecas'], item['defeitos'])\n",
    "        if tx > 3:\n",
    "            alertas.append(f\"{item['dia']} {item['turno']} | {item['operador']} | {tx:.2f}%\")\n",
    "\n",
    "    if alertas:\n",
    "        for alerta in alertas:\n",
    "            print('ALERTA:', alerta)\n",
    "    else:\n",
    "        print('Nenhum dia com taxa acima de 3%.')\n",
    "\n",
    "\n",
    "def mini_grafico():\n",
    "    print('\\n=== MINI-GRÁFICO DE BARRAS ===')\n",
    "    por_dia = {}\n",
    "    for item in dados_semana:\n",
    "        por_dia[item['dia']] = por_dia.get(item['dia'], 0) + item['pecas']\n",
    "\n",
    "    for dia, total in sorted(por_dia.items()):\n",
    "        barras = '#' * (total // 100)\n",
    "        print(f'{dia:<8} {barras} {total}')\n",
    "\n",
    "\n",
    "resumo_por_turno()\n",
    "melhor_e_pior_dia()\n",
    "ranking_operadores()\n",
    "alertas_defeito()\n",
    "mini_grafico()"
   ]
  }
