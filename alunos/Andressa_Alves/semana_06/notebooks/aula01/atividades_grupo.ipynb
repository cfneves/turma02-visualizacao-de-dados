    "registros = []\n",
    "\n",
    "\n",
    "def registrar_producao():\n",
    "    nome = input('Nome do operador: ').strip()\n",
    "    turno = input('Turno (Manhã/Tarde/Noite): ').strip().capitalize()\n",
    "    quantidade = int(input('Quantidade produzida: '))\n",
    "    defeitos = int(input('Quantidade com defeito: '))\n",
    "\n",
    "    if quantidade < 0 or defeitos < 0:\n",
    "        print('Valores não podem ser negativos.')\n",
    "        return\n",
    "\n",
    "    if defeitos > quantidade:\n",
    "        print('Quantidade com defeito não pode ser maior que a quantidade produzida.')\n",
    "        return\n",
    "\n",
    "    taxa_defeito = (defeitos / quantidade * 100) if quantidade > 0 else 0.0\n",
    "\n",
    "    registros.append({\n",
    "        'operador': nome,\n",
    "        'turno': turno,\n",
    "        'quantidade': quantidade,\n",
    "        'defeitos': defeitos,\n",
    "        'taxa_defeito': taxa_defeito\n",
    "    })\n",
    "\n",
    "    print('\\nRegistro salvo com sucesso!')\n",
    "\n",
    "\n",
    "def ver_registros():\n",
    "    if not registros:\n",
    "        print('\\nNenhum registro encontrado.')\n",
    "        return\n",
    "\n",
    "    print('\\n=== REGISTROS DE PRODUÇÃO ===')\n",
    "    for i, item in enumerate(registros, start=1):\n",
    "        print(f\"\\n[{i}] Operador: {item['operador']}\")\n",
    "        print(f\"    Turno: {item['turno']}\")\n",
    "        print(f\"    Produção: {item['quantidade']}\")\n",
    "        print(f\"    Defeitos: {item['defeitos']}\")\n",
    "        print(f\"    Taxa de defeito: {item['taxa_defeito']:.2f}%\")\n",
    "\n",
    "\n",
    "def ver_estatisticas():\n",
    "    if not registros:\n",
    "        print('\\nNenhum registro encontrado para calcular estatísticas.')\n",
    "        return\n",
    "\n",
    "    total_produzido = sum(item['quantidade'] for item in registros)\n",
    "    total_defeitos = sum(item['defeitos'] for item in registros)\n",
    "    maior_producao = max(item['quantidade'] for item in registros)\n",
    "    menor_producao = min(item['quantidade'] for item in registros)\n",
    "    media_producao = total_produzido / len(registros)\n",
    "    taxa_media_defeito = (total_defeitos / total_produzido * 100) if total_produzido > 0 else 0.0\n",
    "\n",
    "    print('\\n=== ESTATÍSTICAS ===')\n",
    "    print(f'Total produzido: {total_produzido}')\n",
    "    print(f'Total de defeitos: {total_defeitos}')\n",
    "    print(f'Maior produção: {maior_producao}')\n",
    "    print(f'Menor produção: {menor_producao}')\n",
    "    print(f'Média por registro: {media_producao:.2f}')\n",
    "    print(f'Taxa média de defeito: {taxa_media_defeito:.2f}%')\n",
    "\n",
    "\n",
    "while True:\n",
    "    print('\\n===== SISTEMA DE REGISTRO DE PRODUÇÃO =====')\n",
    "    print('[1] Registrar produção de um turno')\n",
    "    print('[2] Ver todos os registros')\n",
    "    print('[3] Ver estatísticas')\n",
    "    print('[4] Sair')\n",
    "\n",
    "    opcao = input('Escolha uma opção: ')\n",
    "\n",
    "    if opcao == '1':\n",
    "        registrar_producao()\n",
    "    elif opcao == '2':\n",
    "        ver_registros()\n",
    "    elif opcao == '3':\n",
    "        ver_estatisticas()\n",
    "    elif opcao == '4':\n",
    "        print('\\nSistema encerrado.')\n",
    "        break\n",
    "    else:\n",
    "        print('\\nOpção inválida. Tente novamente.')"
   ]
