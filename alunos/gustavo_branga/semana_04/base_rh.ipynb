    "print()\n",
    "\n",
    "\n",
    "# percentual de nulos - mais util em bases grandes. para entender a proporção de nulos em cada coluna\n",
    "#len(df) - quantidade total de linhas\n",
    "\n",
    "print((df.isnull().sum() / len(df) * 100).round(2))"
   ]
