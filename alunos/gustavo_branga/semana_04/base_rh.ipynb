    "# df.isnull() cria uma tabela de true e false ( true = nula)\n",
    "#.sum soma os true de cada coluna  ( T = 1 F= 0 )\n",
    "# Rusultado: quantidade de nulos por coluna\n",
    "\n",
    "print( 'Quantidade de nulos por coluna:')\n",
    "print(df.isnull().sum())\n",
    "\n",
    "print()\n",
    "\n",
    "\n",
    "# percentual de nulos - mais util em bases grandes. para entender a proporção de nulos em cada coluna\n",
    "#len(df) - quantidade total de linhas\n",
    "\n",
    "print((df.isnull().sum() / len(df) * 100).round(2))"
